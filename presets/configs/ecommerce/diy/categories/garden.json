{
  "states": [
    {
      "name": "init", "type": "event:start:message",
      "next": "emit_browse"
    },
    {
      "name": "emit_browse", "type": "activity",
      "variables": [
        {"name": "var_category", "type": "static", "value": "garden"},
        {"name": "var_uri_path", "type": "static", "value": "/categories/garden"}
      ],
      "emitter": "web_log",
      "next": "load_statics"
    },
    {
      "name": "load_statics", "type": "subprocess",
      "config": "presets/configs/ecommerce/diy/shared/load_statics.json",
      "next": "load_cat_assets"
    },
    {
      "name": "load_cat_assets", "type": "subprocess:multi:variables",
      "config": "presets/configs/ecommerce/diy/shared/load_cat_image.json",
      "items": [
        [
          {"name": "var_asset_name", "type": "static", "value": "banner"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "garden-hose"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "impact-sprinkler"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "round-shovel"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "bow-rake"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "bypass-pruner"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "wheelbarrow"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "digging-fork"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "hand-trowel"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "kneeling-pad"}
        ],
        [
          {"name": "var_asset_name", "type": "static", "value": "garden-dibber"}
        ]
      ],
      "next": "pause_browse"
    },
    {
      "name": "pause_browse", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 15.0, "max": 45.0},
      "next": "route_after_cat"
    },
    {
      "name": "route_after_cat", "type": "gateway:exclusive",
      "transitions": [
        {"next": "emit_view_product", "probability": 0.75},
        {"next": "done", "probability": 0.25}
      ]
    },
    {
      "name": "emit_view_product", "type": "activity",
      "variables": [
        {
          "name": "var_product", "type": "generator:enum",
          "values": [
            "garden-hose", "impact-sprinkler", "round-shovel", "bow-rake",
            "bypass-pruner", "wheelbarrow", "digging-fork", "hand-trowel",
            "kneeling-pad", "garden-dibber"
          ],
          "cardinality_distribution": {"type": "exponential", "mean": 2.0}
        },
        {"name": "var_uri_path", "type": "variable:template", "template": "/categories/{{ var_category }}/{{ var_product }}"}
      ],
      "emitter": "web_log",
      "next": "load_product_assets"
    },
    {
      "name": "load_product_assets", "type": "subprocess",
      "config": "presets/configs/ecommerce/diy/shared/load_product_assets.json",
      "next": "pause_view_product"
    },
    {
      "name": "pause_view_product", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 5.0, "max": 20.0},
      "next": "route_after_product"
    },
    {
      "name": "route_after_product", "type": "gateway:exclusive",
      "transitions": [
        {"next": "emit_view_product", "probability": 0.25},
        {"next": "emit_browse", "probability": 0.15},
        {"next": "add_to_cart", "probability": 0.45},
        {"next": "done", "probability": 0.15}
      ]
    },
    {
      "name": "add_to_cart", "type": "subprocess",
      "config": "presets/configs/ecommerce/diy/shared/add_to_cart.json",
      "next": "done"
    },
    {"name": "done", "type": "event:end"}
  ]
}
