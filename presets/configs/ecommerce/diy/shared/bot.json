            "/categories/electrical", "/categories/paint", "/categories/lumber",
            "/categories/garden", "/categories/power-tools/drill",
            "/categories/power-tools/circular-saw",
            "/categories/power-tools/orbital-sander",
            "/categories/hand-tools/hammer",
            "/categories/hand-tools/screwdriver-set",
            "/categories/hand-tools/tape-measure",
            "/categories/plumbing/ball-valve",
            "/categories/plumbing/shower-head",
            "/categories/electrical/multimeter",
            "/categories/electrical/circuit-breaker",
            "/categories/paint/roller-kit", "/categories/paint/spray-paint",
