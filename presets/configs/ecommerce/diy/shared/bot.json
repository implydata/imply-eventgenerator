        {"name": "var_http_referrer", "type": "static", "value": "-"},
        {"name": "var_http_version", "type": "static", "value": "HTTP/1.1"},
        {"name": "var_uri_query", "type": "static", "value": ""},
        {"name": "var_user", "type": "static", "value": "-"},
        {
          "name": "var_http_user_agent", "type": "generator:enum",
          "values": [
            "Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)",
            "Mozilla/5.0 (compatible; bingbot/2.0; +http://www.bing.com/bingbot.htm)",
            "Mozilla/5.0 (compatible; Applebot/0.1; +http://www.apple.com/go/applebot)",
