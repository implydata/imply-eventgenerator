{
  "templates": {
    "aws:cloudwatchlogs:vpcflow": {
      "body": "{{ version }} {{ account_id }} {{ interface_id }} {{ srcaddr }} {{ dstaddr }} {{ srcport }} {{ dstport }} {{ protocol }} {{ packets }} {{ bytes }} {{ start.timestamp()|int }} {{ end.timestamp()|int }} {{ action }} {{ log_status }}"
    }
  },
  "_comment": "AWS VPC Flow Logs Generator - Models realistic VPC traffic patterns",
  "_description": "This configuration generates AWS VPC Flow Log records that simulate various traffic scenarios including web traffic, database connections, SSH sessions, internal API calls, and malicious patterns like port scans. Each flow represents a network connection with proper lifecycle modeling.",
  "_vpc_flow_log_format": "version account-id interface-id srcaddr dstaddr srcport dstport protocol packets bytes start end action log-status",
  "_design_notes": {
    "traffic_distribution": "40% web, 25% database, 10% SSH, 20% internal APIs, 3% port scans, 2% DNS",
    "ip_ranges": {
      "internal": "10.0.0.0/16",
      "web_servers": "10.0.0.0-10.0.0.4",
      "app_servers": "10.0.0.0-10.0.0.9",
      "db_servers": "10.0.1.0-10.0.1.2",
      "microservices": "10.0.2.0-10.0.2.19"
    },
    "protocols": {
      "tcp": 6,
      "udp": 17,
      "icmp": 1
    },
    "state_machine": "Start->Activity->Emit pattern: Start captures connection vars & var_start, Activity delays for flow duration, Emit captures var_end/packets/bytes and outputs, Continue loops back with new var_start"
  },
  "emitters": [
    {
      "name": "vpc_flow_log",
      "dimensions": [
        {"name": "log_status", "type": "static", "value": "OK"},
        {"name": "account_id", "type": "variable", "variable": "var_account_id"},
        {"name": "action", "type": "variable", "variable": "var_action"},
        {"name": "bytes", "type": "variable", "variable": "var_bytes"},
        {"name": "dstaddr", "type": "variable", "variable": "var_dstaddr"},
        {"name": "dstport", "type": "variable", "variable": "var_dstport"},
        {"name": "end", "type": "variable", "variable": "var_end"},
        {"name": "interface_id", "type": "variable", "variable": "var_interface_id"},
        {"name": "packets", "type": "variable", "variable": "var_packets"},
        {"name": "protocol", "type": "variable", "variable": "var_protocol"},
        {"name": "srcaddr", "type": "variable", "variable": "var_srcaddr"},
        {"name": "srcport", "type": "variable", "variable": "var_srcport"},
        {"name": "start", "type": "variable", "variable": "var_start"},
        {
          "name": "version", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 2
          },
          "_comment": "VPC Flow Logs version 2"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "connection_start", "type": "event:start:timer",
      "cardinality_distribution": {
        "type": "exponential",
        "mean": 0.5,
        "_comment": "New connections initiated every ~0.5 seconds on average"
      },
      "next": "setup_initial"
    },
    {
      "name": "setup_initial", "type": "activity",
      "_comment": "Entry point - routes to specific traffic patterns (no output emitted)",
      "variables": [
        {"name": "var_action", "type": "static", "value": "ACCEPT"},
        {
          "name": "var_account_id", "type": "generator:enum",
          "values": ["123456789012", "123456789013", "123456789014"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 2}
        },
        {
          "name": "var_interface_id", "type": "generator:enum",
          "values": [
            "eni-0a1b2c3d4e5f60001", "eni-0a1b2c3d4e5f60002",
            "eni-0a1b2c3d4e5f60003", "eni-0a1b2c3d4e5f60004",
            "eni-0a1b2c3d4e5f60005", "eni-0a1b2c3d4e5f60006"
          ],
          "cardinality_distribution": {"type": "exponential", "mean": 2},
          "_comment": "ENI selected once per connection - all flow records use same interface"
        }
      ],
      "next": "route_initial"
    },
    {
      "name": "route_initial", "type": "gateway:exclusive",
      "transitions": [
        {"next": "setup_web_traffic_syn", "probability": 0.4},
        {"next": "setup_database_traffic_syn", "probability": 0.25},
        {"next": "setup_ssh_traffic_syn", "probability": 0.1},
        {"next": "setup_internal_api_syn", "probability": 0.2},
        {"next": "setup_port_scan", "probability": 0.03},
        {"next": "setup_dns_traffic", "probability": 0.02}
      ]
    },
    {
      "name": "setup_web_traffic_syn", "type": "activity",
      "_comment": "Setup web SYN: capture connection 5-tuple and var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock", "_comment": "Capture SYN flow start time before delay"},
        {
          "name": "var_dstport", "type": "generator:enum",
          "values": [80, 443],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 1}
        },
        {
          "name": "var_protocol", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 6
          },
          "_comment": "TCP"
        },
        {
          "name": "var_srcport", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          },
          "_comment": "Ephemeral ports"
        },
        {
          "name": "var_dstaddr", "type": "generator:ipaddress",
          "cardinality": 5,
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 167772164
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 4},
          "_comment": "Web servers (10.0.0.0-10.0.0.4)"
        },
        {
          "name": "var_srcaddr", "type": "generator:ipaddress",
          "cardinality": 1000,
          "distribution": {
            "type": "uniform",
            "min": 134744064,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100},
          "_comment": "External IPs (8.8.0.0 - 223.255.255.255)"
        }
      ],
      "next": "pause_web_traffic_syn"
    },
    {
      "name": "pause_web_traffic_syn", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_web_traffic_syn"
    },
    {
      "name": "emit_web_traffic_syn", "type": "activity",
      "_comment": "TCP SYN - Capture connection 5-tuple & var_start, delay for handshake (1-2s), emit flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock", "_comment": "Capture end time after handshake delay"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 180,
            "max": 240
          },
          "_comment": "TCP handshake packets"
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 3
          },
          "_comment": "SYN, SYN-ACK, ACK"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "route_web_traffic_syn"
    },
    {
      "name": "route_web_traffic_syn", "type": "gateway:exclusive",
      "transitions": [
        {"next": "setup_web_traffic_data", "probability": 0.95},
        {"next": "setup_web_traffic_rst", "probability": 0.05}
      ]
    },
    {
      "name": "setup_web_traffic_data", "type": "activity",
      "_comment": "Setup web data: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_web_traffic_data"
    },
    {
      "name": "pause_web_traffic_data", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 10.0},
      "next": "emit_web_traffic_data"
    },
    {
      "name": "emit_web_traffic_data", "type": "activity",
      "_comment": "Data transfer - Capture var_start, delay for data transfer (1-10s), emit flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock", "_comment": "Capture flow window end time (after activity delay)"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 5000,
            "max": 500000
          },
          "_comment": "5KB to 500KB"
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 50,
            "max": 500
          }
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "route_web_traffic_data"
    },
    {
      "name": "route_web_traffic_data", "type": "gateway:exclusive",
      "transitions": [
        {"next": "route_web_traffic_continue", "probability": 0.25},
        {"next": "setup_web_traffic_fin", "probability": 0.75}
      ]
    },
    {
      "name": "route_web_traffic_continue", "type": "gateway:exclusive",
      "_comment": "Web traffic - Continue: Loop back for next data window",
      "transitions": [
        {"next": "setup_web_traffic_data", "probability": 1.0}
      ]
    },
    {
      "name": "setup_web_traffic_fin", "type": "activity",
      "_comment": "Setup web FIN: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_web_traffic_fin"
    },
    {
      "name": "pause_web_traffic_fin", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_web_traffic_fin"
    },
    {
      "name": "emit_web_traffic_fin", "type": "activity",
      "_comment": "TCP FIN - Capture var_start, delay for FIN handshake (1-2s), emit close record",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 100,
            "max": 140
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 2
          },
          "_comment": "FIN, ACK"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "connection_end"
    },
    {
      "name": "setup_web_traffic_rst", "type": "activity",
      "_comment": "Setup web RST: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_web_traffic_rst"
    },
    {
      "name": "pause_web_traffic_rst", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_web_traffic_rst"
    },
    {
      "name": "emit_web_traffic_rst", "type": "activity",
      "_comment": "TCP RST - Capture var_start, delay for RST (1-2s), emit reset record",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 50,
            "max": 70
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 1
          },
          "_comment": "RST packet"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "connection_end"
    },
    {
      "name": "setup_database_traffic_syn", "type": "activity",
      "_comment": "Setup database SYN: capture connection 5-tuple and var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"},
        {
          "name": "var_dstport", "type": "generator:enum",
          "values": [3306, 5432, 1433, 27017],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 3},
          "_comment": "MySQL, PostgreSQL, SQL Server, MongoDB"
        },
        {
          "name": "var_protocol", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 6
          }
        },
        {
          "name": "var_srcport", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_dstaddr", "type": "generator:ipaddress",
          "cardinality": 3,
          "distribution": {
            "type": "uniform",
            "min": 167772416,
            "max": 167772418
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 2},
          "_comment": "DB servers (10.0.1.0-10.0.1.2)"
        },
        {
          "name": "var_srcaddr", "type": "generator:ipaddress",
          "cardinality": 10,
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 167772169
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 9},
          "_comment": "App servers (10.0.0.0-10.0.0.9)"
        }
      ],
      "next": "pause_database_traffic_syn"
    },
    {
      "name": "pause_database_traffic_syn", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_database_traffic_syn"
    },
    {
      "name": "emit_database_traffic_syn", "type": "activity",
      "_comment": "TCP SYN - Capture connection 5-tuple & var_start, delay for handshake (1-2s), emit flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock", "_comment": "Capture end time after handshake delay"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 180,
            "max": 240
          },
          "_comment": "TCP handshake packets"
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 3
          },
          "_comment": "SYN, SYN-ACK, ACK"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "route_database_traffic_syn"
    },
    {
      "name": "route_database_traffic_syn", "type": "gateway:exclusive",
      "transitions": [
        {"next": "setup_database_traffic_data", "probability": 0.95},
        {"next": "setup_database_traffic_rst", "probability": 0.05}
      ]
    },
    {
      "name": "setup_database_traffic_data", "type": "activity",
      "_comment": "Setup database data: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_database_traffic_data"
    },
    {
      "name": "pause_database_traffic_data", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 3.0},
      "next": "emit_database_traffic_data"
    },
    {
      "name": "emit_database_traffic_data", "type": "activity",
      "_comment": "Database traffic - Data: Query execution with flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 1000,
            "max": 100000
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 10,
            "max": 200
          }
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "route_database_traffic_data"
    },
    {
      "name": "route_database_traffic_data", "type": "gateway:exclusive",
      "transitions": [
        {"next": "route_database_traffic_continue", "probability": 0.6},
        {"next": "setup_database_traffic_fin", "probability": 0.4}
      ]
    },
    {
      "name": "route_database_traffic_continue", "type": "gateway:exclusive",
      "_comment": "Database traffic - Continue: Loop back for next query",
      "transitions": [
        {"next": "setup_database_traffic_data", "probability": 1.0}
      ]
    },
    {
      "name": "setup_database_traffic_fin", "type": "activity",
      "_comment": "Setup database FIN: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_database_traffic_fin"
    },
    {
      "name": "pause_database_traffic_fin", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_database_traffic_fin"
    },
    {
      "name": "emit_database_traffic_fin", "type": "activity",
      "_comment": "TCP FIN - Graceful connection close",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 100,
            "max": 140
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 2
          },
          "_comment": "FIN, ACK"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "connection_end"
    },
    {
      "name": "setup_database_traffic_rst", "type": "activity",
      "_comment": "Setup database RST: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_database_traffic_rst"
    },
    {
      "name": "pause_database_traffic_rst", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_database_traffic_rst"
    },
    {
      "name": "emit_database_traffic_rst", "type": "activity",
      "_comment": "TCP RST - Connection reset/refused",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 50,
            "max": 70
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 1
          },
          "_comment": "RST packet"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "connection_end"
    },
    {
      "name": "setup_ssh_traffic_syn", "type": "activity",
      "_comment": "Setup SSH SYN: capture connection 5-tuple and var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"},
        {
          "name": "var_dstport", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 22
          }
        },
        {
          "name": "var_protocol", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 6
          }
        },
        {
          "name": "var_srcport", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_dstaddr", "type": "generator:ipaddress",
          "cardinality": 15,
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 167772174
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 14},
          "_comment": "Internal servers (10.0.0.0-10.0.0.14)"
        },
        {
          "name": "var_srcaddr", "type": "generator:ipaddress",
          "cardinality": 20,
          "distribution": {
            "type": "uniform",
            "min": 134744064,
            "max": 184549375
          },
          "cardinality_distribution": {"type": "exponential", "mean": 5},
          "_comment": "Corporate IPs / VPN"
        }
      ],
      "next": "pause_ssh_traffic_syn"
    },
    {
      "name": "pause_ssh_traffic_syn", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 2.0},
      "next": "emit_ssh_traffic_syn"
    },
    {
      "name": "emit_ssh_traffic_syn", "type": "activity",
      "_comment": "TCP SYN - Capture connection 5-tuple & var_start, delay for handshake (1-2s), emit flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock", "_comment": "Capture end time after handshake delay"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 180,
            "max": 240
          },
          "_comment": "TCP handshake packets"
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 3
          },
          "_comment": "SYN, SYN-ACK, ACK"
        }
      ],
      "emitter": "vpc_flow_log",
      "next": "route_ssh_traffic_syn"
    },
    {
      "name": "route_ssh_traffic_syn", "type": "gateway:exclusive",
      "transitions": [
        {"next": "setup_ssh_traffic_data", "probability": 0.95},
        {"next": "setup_ssh_traffic_rst", "probability": 0.05}
      ]
    },
    {
      "name": "setup_ssh_traffic_data", "type": "activity",
      "_comment": "Setup SSH data: capture var_start before timer delay",
      "variables": [
        {"name": "var_start", "type": "generator:clock"}
      ],
      "next": "pause_ssh_traffic_data"
    },
    {
      "name": "pause_ssh_traffic_data", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 1.0, "max": 40.0},
      "next": "emit_ssh_traffic_data"
    },
    {
      "name": "emit_ssh_traffic_data", "type": "activity",
      "_comment": "SSH traffic - Data: Session activity with flow record",
      "variables": [
        {"name": "var_end", "type": "generator:clock"},
        {
          "name": "var_bytes", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 10000,
            "max": 200000
          }
        },
        {
          "name": "var_packets", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 100,
            "max": 2000
          }
        }
