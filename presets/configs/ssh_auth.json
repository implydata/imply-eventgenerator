{
  "templates": {
    "linux_secure": {
      "body": "{{ time.strftime('%b %d %H:%M:%S') }} {{ hostname }} sshd[{{ pid }}]: {% if line_type == 'auth' %}{{ action }} for {{ user }} from {{ src_ip }} port {{ src_port }} ssh2{% else %}pam_unix(sshd:session): {{ action }} for user {{ user }}{% endif %}"
    }
  },
  "_description": "Linux SSH authentication log (linux_secure sourcetype). Models SSH connection lifecycle: brute-force attempts loop on failed_password before either giving up or succeeding; successful logins proceed to session_opened then session_closed.",
  "emitters": [
    {
      "name": "ssh_log",
      "dimensions": [
        {"type": "clock", "name": "time"},
        {"type": "variable", "name": "action", "variable": "var_action"},
        {"type": "variable", "name": "hostname", "variable": "var_hostname"},
        {"type": "variable", "name": "line_type", "variable": "var_line_type"},
        {"type": "variable", "name": "pid", "variable": "var_pid"},
        {"type": "variable", "name": "src_ip", "variable": "var_src_ip"},
        {"type": "variable", "name": "src_port", "variable": "var_src_port"},
        {"type": "variable", "name": "user", "variable": "var_user"}
      ]
    }
  ],
  "states": [
    {
      "type": "event:start:timer", "name": "session_start",
      "timer": {"type": "exponential", "mean": 10.0},
      "next": "setup_session"
    },
    {
      "type": "activity", "name": "setup_session",
      "variables": [
        {
          "type": "enum", "name": "var_hostname",
          "values": ["web01", "web02", "db01", "app01", "bastion"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 4}
        },
        {
          "type": "enum", "name": "var_user",
          "values": ["root", "admin", "deploy", "ubuntu", "ec2-user", "git", "jenkins", "ansible"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 7}
        },
        {
          "type": "int", "name": "var_pid",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 1000,
            "max": 65535
          }
        },
        {
          "type": "int", "name": "var_src_port",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 1024,
            "max": 65535
          }
        },
        {
          "type": "ipaddress", "name": "var_src_ip",
          "cardinality": 200,
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 50}
        }
      ],
      "next": "route_initial"
    },
    {
      "type": "gateway:exclusive", "name": "route_initial",
      "transitions": [
        {"next": "pause_failed_password", "probability": 0.4},
        {"next": "pause_accepted", "probability": 0.6}
      ]
    },
    {
      "type": "event:intermediate:timer", "name": "pause_failed_password",
      "delay": {"type": "exponential", "mean": 3.0},
      "next": "emit_failed_password"
    },
    {
      "type": "activity", "name": "emit_failed_password",
      "emitter": "ssh_log",
      "variables": [
        {
          "type": "enum", "name": "var_action",
          "values": ["Failed password"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_line_type",
          "values": ["auth"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        }
      ],
      "next": "route_failed_password"
    },
    {
      "type": "gateway:exclusive", "name": "route_failed_password",
      "transitions": [
        {"next": "pause_failed_password", "probability": 0.35},
        {"next": "pause_accepted", "probability": 0.05},
        {"next": "session_end", "probability": 0.6}
      ]
    },
    {
      "type": "event:intermediate:timer", "name": "pause_accepted",
      "delay": {"type": "uniform", "min": 0.1, "max": 1.0},
      "next": "emit_accepted"
    },
    {
      "type": "activity", "name": "emit_accepted",
      "emitter": "ssh_log",
      "variables": [
        {
          "type": "enum", "name": "var_action",
          "values": ["Accepted password"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_line_type",
          "values": ["auth"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        }
      ],
      "next": "pause_session_opened"
    },
    {
      "type": "event:intermediate:timer", "name": "pause_session_opened",
      "delay": {"type": "exponential", "mean": 600.0},
      "next": "emit_session_opened"
    },
    {
      "type": "activity", "name": "emit_session_opened",
      "emitter": "ssh_log",
      "variables": [
        {
          "type": "enum", "name": "var_action",
          "values": ["session opened"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_line_type",
          "values": ["session"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        }
      ],
      "next": "pause_session_closed"
    },
    {
      "type": "event:intermediate:timer", "name": "pause_session_closed",
      "delay": {"type": "uniform", "min": 0.1, "max": 0.5},
      "next": "emit_session_closed"
    },
    {
      "type": "activity", "name": "emit_session_closed",
      "emitter": "ssh_log",
      "variables": [
        {
          "type": "enum", "name": "var_action",
          "values": ["session closed"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_line_type",
          "values": ["session"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        }
      ],
      "next": "session_end"
    },
    {"type": "event:end", "name": "session_end"}
  ]
}
