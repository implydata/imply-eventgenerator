{
  "emitters": [
    {
      "name": "loop_emit",
      "dimensions": [
        {"name": "time", "type": "clock"},
        {"name": "item", "type": "variable", "variable": "item"},
        {
          "name": "event", "type": "enum",
          "values": ["loop"],
          "cardinality_distribution": {"type": "constant", "value": 0}
        }
      ]
    }
  ],
  "states": [
    {
      "name": "init", "type": "event:start:timer",
      "cardinality_distribution": {"type": "constant", "value": 1},
      "next": "load_delay"
    },
    {
      "name": "load_delay", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 0.1, "max": 0.5},
      "next": "emit_loop"
    },
    {
      "name": "emit_loop", "type": "activity",
      "emitter": "loop_emit",
      "next": "done"
    },
    {"name": "done", "type": "event:end"}
  ]
}
