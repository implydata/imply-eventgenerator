{
  "templates": {
    "WindowsFirewallLog": {
      "body": "{{ time.strftime('%Y-%m-%d') }} {{ time.strftime('%H:%M:%S') }} {{ win_action }} {{ transport }} {{ src }} {{ dest }} {{ src_port }} {{ dest_port }} {{ size }} - - - - - - {{ direction }} -"
    }
  },
  "_description": "Windows Firewall log (WindowsFirewallLog sourcetype). Models the traffic an internet-facing Windows host sees: inbound HTTP/HTTPS, RDP, SMB probes, SMTP, port scanning — plus outbound DNS and Windows Update. High DROP rate reflects typical internet exposure.",
  "emitters": [
    {
      "name": "inbound_log",
      "_comment": "Inbound traffic: internet IP is src, local host IP is dest",
      "dimensions": [
        {"name": "time", "type": "generator:clock"},
        {"name": "direction", "type": "static", "value": "RECEIVE"},
        {"name": "dest", "type": "variable", "variable": "var_local_ip"},
        {"name": "dest_port", "type": "variable", "variable": "var_dest_port"},
        {"name": "size", "type": "variable", "variable": "var_size"},
        {"name": "src", "type": "variable", "variable": "var_internet_ip"},
        {"name": "src_port", "type": "variable", "variable": "var_src_port"},
        {"name": "transport", "type": "variable", "variable": "var_transport"},
        {"name": "win_action", "type": "variable", "variable": "var_win_action"}
      ]
    },
    {
      "name": "outbound_log",
      "_comment": "Outbound traffic: local host IP is src, internet IP is dest",
      "dimensions": [
        {"name": "time", "type": "generator:clock"},
        {"name": "direction", "type": "static", "value": "SEND"},
        {"name": "dest", "type": "variable", "variable": "var_internet_ip"},
        {"name": "dest_port", "type": "variable", "variable": "var_dest_port"},
        {"name": "size", "type": "variable", "variable": "var_size"},
        {"name": "src", "type": "variable", "variable": "var_local_ip"},
        {"name": "src_port", "type": "variable", "variable": "var_src_port"},
        {"name": "transport", "type": "variable", "variable": "var_transport"},
        {"name": "win_action", "type": "variable", "variable": "var_win_action"}
      ]
    }
  ],
  "states": [
    {
      "name": "connection_start", "type": "event:start:timer",
      "cardinality_distribution": {
        "type": "exponential",
        "mean": 0.3,
        "_comment": "Internet-facing host sees ~3 connection attempts per second on average"
      },
      "next": "setup_connection"
    },
    {
      "name": "setup_connection", "type": "activity",
      "variables": [
        {"name": "var_transport", "type": "static", "value": "TCP"},
        {
          "name": "var_local_ip", "type": "generator:ipaddress",
          "cardinality": 5,
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 167772415
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 4},
          "_comment": "10.0.0.0/24 — small pool of local Windows hosts"
        }
      ],
      "next": "route_initial"
    },
    {
      "name": "route_initial", "type": "gateway:exclusive",
      "transitions": [
        {"next": "emit_inbound_https", "probability": 0.255},
        {"next": "emit_inbound_https_drop", "probability": 0.045},
        {"next": "emit_inbound_http", "probability": 0.12},
        {"next": "emit_inbound_http_drop", "probability": 0.03},
        {"next": "emit_inbound_rdp", "probability": 0.05},
        {"next": "emit_inbound_rdp_drop", "probability": 0.15},
        {"next": "emit_inbound_smb_drop", "probability": 0.1},
        {"next": "emit_inbound_smtp", "probability": 0.048},
        {"next": "emit_inbound_smtp_drop", "probability": 0.032},
        {"next": "emit_inbound_scan", "probability": 0.03},
        {"next": "emit_outbound_dns", "probability": 0.04},
        {"next": "emit_outbound_update", "probability": 0.1}
      ]
    },
    {
      "name": "emit_inbound_https", "type": "activity",
      "_comment": "HTTPS (443) inbound — ALLOW (85% of HTTPS traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 443
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 1500
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_https_drop", "type": "activity",
      "_comment": "HTTPS (443) inbound — DROP (15% of HTTPS traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 443
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 200
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_http", "type": "activity",
      "_comment": "HTTP (80) inbound — ALLOW (80% of HTTP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 80
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 1500
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_http_drop", "type": "activity",
      "_comment": "HTTP (80) inbound — DROP (20% of HTTP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 80
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 200
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_rdp", "type": "activity",
      "_comment": "RDP (3389) inbound — ALLOW. Authorised remote desktop (25% of RDP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 3389
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 200
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 20,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 5}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_rdp_drop", "type": "activity",
      "_comment": "RDP (3389) inbound — DROP. Brute-force/scanning from internet (75% of RDP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 3389
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 80
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 300,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 30}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_smb_drop", "type": "activity",
      "_comment": "SMB (445) inbound — DROP. Should never be open to the internet; all attempts blocked.",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 445
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 80
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 200,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 20}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_smtp", "type": "activity",
      "_comment": "SMTP (25) inbound — ALLOW. Legitimate email delivery (60% of SMTP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 25
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 800
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 400,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 80}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_smtp_drop", "type": "activity",
      "_comment": "SMTP (25) inbound — DROP. Spam/relay attempts blocked by policy (40% of SMTP traffic).",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 25
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 200
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 400,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 80}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_inbound_scan", "type": "activity",
      "_comment": "Port scan — random destination port, always DROPped. 3% of traffic.",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "DROP"},
        {
          "name": "var_transport", "type": "generator:enum",
          "values": ["TCP", "UDP"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 1}
        },
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 1,
            "max": 65535
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 80
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 1024,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 100,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 10}
        }
      ],
      "emitter": "inbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_outbound_dns", "type": "activity",
      "_comment": "DNS (53) outbound — ALLOW. Host resolving names.",
      "variables": [
        {"name": "var_transport", "type": "static", "value": "UDP"},
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 53
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 120
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 4,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 3},
          "_comment": "Small pool of DNS resolvers"
        }
      ],
      "emitter": "outbound_log",
      "next": "connection_end"
    },
    {
      "name": "emit_outbound_update", "type": "activity",
      "_comment": "HTTPS (443) outbound — ALLOW. Windows Update, telemetry, cloud agent traffic.",
      "variables": [
        {"name": "var_win_action", "type": "static", "value": "ALLOW"},
        {
          "name": "var_dest_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 443
          }
        },
        {
          "name": "var_size", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 1500
          }
        },
        {
          "name": "var_src_port", "type": "generator:int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_internet_ip", "type": "generator:ipaddress",
          "cardinality": 20,
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          },
          "cardinality_distribution": {"type": "exponential", "mean": 5},
          "_comment": "Microsoft CDN and update endpoints"
        }
      ],
      "emitter": "outbound_log",
      "next": "connection_end"
    },
    {"name": "connection_end", "type": "event:end"}
  ]
}
