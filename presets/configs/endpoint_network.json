{
  "templates": {
    "WindowsFirewallLog": {
      "body": "{{ time.strftime('%Y-%m-%d') }} {{ time.strftime('%H:%M:%S') }} {{ win_action }} {{ transport }} {{ src }} {{ dest }} {{ src_port }} {{ dest_port }} {{ size }} - - - - - - {{ direction }} -"
    }
  },
  "_description": "Windows Firewall log (WindowsFirewallLog sourcetype). Models the traffic an internet-facing Windows host sees: inbound HTTP/HTTPS, RDP, SMB probes, SMTP, port scanning \u2014 plus outbound DNS and Windows Update. High DROP rate reflects typical internet exposure.",
  "emitters": [
    {
      "name": "inbound_log",
      "_comment": "Inbound traffic: internet IP is src, local host IP is dest",
      "dimensions": [
        {
          "name": "time",
          "type": "clock"
        },
        {
          "name": "win_action",
          "type": "variable",
          "variable": "var_win_action"
        },
        {
          "name": "transport",
          "type": "variable",
          "variable": "var_transport"
        },
        {
          "name": "src",
          "type": "variable",
          "variable": "var_internet_ip"
        },
        {
          "name": "dest",
          "type": "variable",
          "variable": "var_local_ip"
        },
        {
          "name": "src_port",
          "type": "variable",
          "variable": "var_src_port"
        },
        {
          "name": "dest_port",
          "type": "variable",
          "variable": "var_dest_port"
        },
        {
          "name": "size",
          "type": "variable",
          "variable": "var_size"
        },
        {
          "name": "direction",
          "type": "enum",
          "values": [
            "RECEIVE"
          ],
          "cardinality_distribution": {
            "type": "constant",
            "value": 0
          }
        }
      ]
    },
    {
      "name": "outbound_log",
      "_comment": "Outbound traffic: local host IP is src, internet IP is dest",
      "dimensions": [
        {
          "name": "time",
          "type": "clock"
        },
        {
          "name": "win_action",
          "type": "variable",
          "variable": "var_win_action"
        },
        {
          "name": "transport",
          "type": "variable",
          "variable": "var_transport"
        },
        {
          "name": "src",
          "type": "variable",
          "variable": "var_local_ip"
        },
        {
          "name": "dest",
          "type": "variable",
          "variable": "var_internet_ip"
        },
        {
          "name": "src_port",
          "type": "variable",
          "variable": "var_src_port"
        },
        {
          "name": "dest_port",
          "type": "variable",
          "variable": "var_dest_port"
        },
        {
          "name": "size",
          "type": "variable",
          "variable": "var_size"
        },
        {
          "name": "direction",
          "type": "enum",
          "values": [
            "SEND"
          ],
          "cardinality_distribution": {
            "type": "constant",
            "value": 0
          }
        }
      ]
    }
  ],
  "states": [
    {
      "name": "connection_start",
      "type": "event:start:timer",
      "timer": {
        "type": "exponential",
        "mean": 0.3,
        "_comment": "Internet-facing host sees ~3 connection attempts per second on average"
      },
      "next": "setup_initial"
    },
    {
      "name": "setup_initial",
      "_comment": "Sets the local host IP, then routes to traffic type.",
      "variables": [
        {
          "name": "var_local_ip",
          "type": "ipaddress",
          "cardinality": 5,
          "cardinality_distribution": {
            "type": "uniform",
            "min": 0,
            "max": 4
          },
          "distribution": {
            "type": "uniform",
            "min": 167772160,
            "max": 167772415
          },
          "_comment": "10.0.0.0/24 \u2014 small pool of local Windows hosts"
        }
      ],
      "type": "activity",
      "next": "route_initial"
    },
    {
      "name": "route_initial",
      "type": "gateway:exclusive",
      "transitions": [
        {
          "next": "emit_inbound_https",
          "probability": 0.255
        },
        {
          "next": "emit_inbound_https_drop",
          "probability": 0.045
        },
        {
          "next": "emit_inbound_http",
          "probability": 0.12
        },
        {
          "next": "emit_inbound_http_drop",
          "probability": 0.03
        },
        {
          "next": "emit_inbound_rdp",
          "probability": 0.05
        },
        {
          "next": "emit_inbound_rdp_drop",
          "probability": 0.15
        },
        {
          "next": "emit_inbound_smb_drop",
          "probability": 0.1
        },
        {
          "next": "emit_inbound_smtp",
          "probability": 0.048
        },
        {
          "next": "emit_inbound_smtp_drop",
          "probability": 0.032
        },
        {
          "next": "emit_inbound_scan",
          "probability": 0.03
        },
        {
          "next": "emit_outbound_dns",
          "probability": 0.04
        },
        {
          "next": "emit_outbound_update",
          "probability": 0.1
        }
      ]
    },
    {
      "name": "emit_inbound_https",
      "_comment": "HTTPS (443) inbound \u2014 ALLOW (85% of HTTPS traffic).",
      "emitter": "inbound_log",
      "variables": [
        {
          "name": "var_win_action",
          "type": "enum",
          "values": [
            "ALLOW"
          ],
          "cardinality_distribution": {
            "type": "constant",
            "value": 0
          }
        },
        {
          "name": "var_transport",
          "type": "enum",
          "values": [
            "TCP"
          ],
          "cardinality_distribution": {
            "type": "constant",
            "value": 0
          }
        },
        {
          "name": "var_internet_ip",
          "type": "ipaddress",
          "cardinality": 500,
          "cardinality_distribution": {
            "type": "exponential",
            "mean": 100
          },
          "distribution": {
            "type": "uniform",
            "min": 16777216,
            "max": 3758096383
          }
        },
        {
          "name": "var_src_port",
          "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 49152,
            "max": 65535
          }
        },
        {
          "name": "var_dest_port",
          "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "constant",
            "value": 443
          }
        },
        {
          "name": "var_size",
          "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 40,
            "max": 1500
          }
        }
      ],
      "type": "activity",
      "next": "connection_end"
    },
