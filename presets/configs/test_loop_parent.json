{
  "emitters": [
    {
      "name": "pageview_emit",
      "dimensions": [
        {"name": "time", "type": "clock"},
        {
          "name": "event", "type": "enum",
          "values": ["pageview"],
          "cardinality_distribution": {"type": "constant", "value": 0}
        }
      ]
    }
  ],
  "states": [
    {
      "name": "init", "type": "event:start:timer",
      "cardinality_distribution": {"type": "constant", "value": 1},
      "next": "emit_pageview"
    },
    {
      "name": "emit_pageview", "type": "activity",
      "emitter": "pageview_emit",
      "next": "load_components"
    },
    {
      "name": "load_components", "type": "subprocess:multi_instance",
      "in": [
        [
          {"name": "url", "type": "string:static", "value": "/index.html"},
          {"name": "bytes", "type": "int:static", "value": 1247}
        ],
        [
          {"name": "url", "type": "string:static", "value": "/static/style.css"},
          {"name": "bytes", "type": "int:static", "value": 8432}
        ],
        [
          {"name": "url", "type": "string:static", "value": "/static/app.js"},
          {"name": "bytes", "type": "int:static", "value": 42180}
        ],
        [
          {"name": "url", "type": "string:static", "value": "/static/logo.png"},
          {"name": "bytes", "type": "int:static", "value": 18920}
        ],
        [
          {"name": "url", "type": "string:static", "value": "/static/hero.jpg"},
          {"name": "bytes", "type": "int:static", "value": 94320}
        ]
      ],
      "states": "presets/configs/test_loop_child.json",
      "next": "done"
    },
    {"name": "done", "type": "event:end"}
  ]
}
