{
  "templates": {
    "asterisk_cdr": {
      "body": "\"{{ accountcode }}\",\"{{ src }}\",\"{{ dst }}\",\"default\",\"{{ src }}\",\"SIP/{{ src }}\",\"{{ dstchannel }}\",\"{{ lastapp }}\",\"{{ lastdata }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",{{ duration }},{% if disposition == 'ANSWERED' %}{{ duration }}{% else %}0{% endif %},\"{{ disposition }}\",\"DOCUMENTATION\""
    }
  },
  "_description": "Asterisk IP PBX call detail records (asterisk_cdr sourcetype). Models the full call lifecycle per caller: initial sets caller/destination, ringing delays until the call is picked up or times out, then the call is answered (with a realistic talk-time delay before the CDR is emitted) or rejected immediately.",
  "emitters": [
    {
      "name": "cdr",
      "dimensions": [
        {"type": "clock", "name": "time"},
        {"type": "variable", "name": "accountcode", "variable": "var_accountcode"},
        {"type": "variable", "name": "disposition", "variable": "var_disposition"},
        {"type": "variable", "name": "dst", "variable": "var_dst"},
        {"type": "variable", "name": "dstchannel", "variable": "var_dstchannel"},
        {"type": "variable", "name": "duration", "variable": "var_duration"},
        {"type": "variable", "name": "lastapp", "variable": "var_lastapp"},
        {"type": "variable", "name": "lastdata", "variable": "var_lastdata"},
        {"type": "variable", "name": "src", "variable": "var_src"}
      ]
    }
  ],
  "states": [
    {
      "type": "event:start:timer", "name": "call_start",
      "timer": {"type": "exponential", "mean": 30.0},
      "next": "setup_call"
    },
    {
      "type": "activity", "name": "setup_call",
      "variables": [
        {
          "type": "enum", "name": "var_accountcode",
          "values": ["", "sales", "support", "billing"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 3}
        },
        {
          "type": "int", "name": "var_dst",
          "cardinality": 20,
          "distribution": {
            "type": "uniform",
            "min": 1000,
            "max": 9999
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 19}
        },
        {
          "type": "int", "name": "var_src",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 2000000000,
            "max": 9999999999
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "next": "route_busy_check"
    },
    {
      "type": "gateway:exclusive", "name": "route_busy_check",
      "_comment": "Busy is determined before ringing — the line is either free or engaged.",
      "transitions": [
        {"next": "pause_busy", "probability": 0.1},
        {"next": "pause_ringing", "probability": 0.9}
      ]
    },
    {
      "type": "event:intermediate:timer", "name": "pause_busy",
      "_comment": "Busy signal is near-instantaneous.",
      "delay": {"type": "uniform", "min": 0.5, "max": 2.0},
      "next": "emit_busy"
    },
    {
      "type": "event:intermediate:timer", "name": "pause_ringing",
      "delay": {"type": "uniform", "min": 5, "max": 30},
      "next": "route_ringing"
    },
    {
      "type": "gateway:exclusive", "name": "route_ringing",
      "_comment": "Phone rang out — either answered or no answer.",
      "transitions": [
        {"next": "pause_answered", "probability": 0.78},
        {"next": "emit_no_answer", "probability": 0.22}
      ]
    },
    {
      "type": "event:intermediate:timer", "name": "pause_answered",
      "delay": {"type": "exponential", "mean": 180},
      "next": "emit_answered"
    },
    {
      "type": "activity", "name": "emit_answered",
      "_comment": "Call is in progress. Delay models talk time. CDR emitted when call ends.",
      "emitter": "cdr",
      "variables": [
        {
          "type": "enum", "name": "var_disposition",
          "values": ["ANSWERED"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_dstchannel",
          "values": ["SIP/trunk-0001", "SIP/trunk-0002", "SIP/trunk-0003"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 2}
        },
        {
          "type": "enum", "name": "var_lastapp",
          "values": ["Dial"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_lastdata",
          "values": ["SIP/trunk,30,tTr"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "int", "name": "var_duration",
          "cardinality": 0,
          "distribution": {
            "type": "exponential",
            "mean": 180
          }
        }
      ],
      "next": "call_end"
    },
    {
      "type": "activity", "name": "emit_no_answer",
      "_comment": "Rang out. CDR emitted immediately with ring duration.",
      "emitter": "cdr",
      "variables": [
        {
          "type": "enum", "name": "var_disposition",
          "values": ["NO ANSWER"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_dstchannel",
          "values": [""],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_lastapp",
          "values": ["Dial"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_lastdata",
          "values": ["SIP/trunk,30,tTr"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "int", "name": "var_duration",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 10,
            "max": 45
          }
        }
      ],
      "next": "call_end"
    },
    {
      "type": "activity", "name": "emit_busy",
      "_comment": "Line busy. CDR emitted immediately.",
      "emitter": "cdr",
      "variables": [
        {
          "type": "enum", "name": "var_disposition",
          "values": ["BUSY"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_dstchannel",
          "values": [""],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_lastapp",
          "values": ["Dial"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "enum", "name": "var_lastdata",
          "values": ["SIP/trunk,30,tTr"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 0}
        },
        {
          "type": "int", "name": "var_duration",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 2,
            "max": 8
          }
        }
      ],
      "next": "call_end"
    },
    {"type": "event:end", "name": "call_end"}
  ]
}
