{
  "templates": {
    "asterisk_cdr": {
      "body": "\"{{ accountcode }}\",\"{{ src }}\",\"{{ dst }}\",\"default\",\"{{ src }}\",\"SIP/{{ src }}\",\"{{ dstchannel }}\",\"{{ lastapp }}\",\"{{ lastdata }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",\"{{ time.strftime('%Y-%m-%d %H:%M:%S') }}\",{{ duration }},{% if disposition == 'ANSWERED' %}{{ duration }}{% else %}0{% endif %},\"{{ disposition }}\",\"DOCUMENTATION\""
    }
  },
  "_description": "Asterisk IP PBX call detail records (asterisk_cdr sourcetype). Models the full call lifecycle per caller: initial sets caller/destination, ringing delays until the call is picked up or times out, then the call is answered (with a realistic talk-time delay before the CDR is emitted) or rejected immediately.",
  "emitters": [
    {
      "name": "cdr",
      "dimensions": [
        {"name": "time", "type": "clock"},
        {"name": "accountcode", "type": "variable", "variable": "var_accountcode"},
        {"name": "disposition", "type": "variable", "variable": "var_disposition"},
        {"name": "dst", "type": "variable", "variable": "var_dst"},
        {"name": "dstchannel", "type": "variable", "variable": "var_dstchannel"},
        {"name": "duration", "type": "variable", "variable": "var_duration"},
        {"name": "lastapp", "type": "variable", "variable": "var_lastapp"},
        {"name": "lastdata", "type": "variable", "variable": "var_lastdata"},
        {"name": "src", "type": "variable", "variable": "var_src"}
      ]
    }
  ],
  "states": [
    {
      "name": "call_start", "type": "event:start:timer",
      "cardinality_distribution": {"type": "exponential", "mean": 30.0},
      "next": "setup_call"
    },
    {
      "name": "setup_call", "type": "activity",
      "variables": [
        {
          "name": "var_accountcode", "type": "enum",
          "values": ["", "sales", "support", "billing"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 3}
        },
        {
          "name": "var_dst", "type": "int",
          "cardinality": 20,
          "distribution": {
            "type": "uniform",
            "min": 1000,
            "max": 9999
          },
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 19}
        },
        {
          "name": "var_src", "type": "int",
          "cardinality": 500,
          "distribution": {
            "type": "uniform",
            "min": 2000000000,
            "max": 9999999999
          },
          "cardinality_distribution": {"type": "exponential", "mean": 100}
        }
      ],
      "next": "route_busy_check"
    },
    {
      "name": "route_busy_check", "type": "gateway:exclusive",
      "_comment": "Busy is determined before ringing — the line is either free or engaged.",
      "transitions": [
        {"next": "pause_busy", "probability": 0.1},
        {"next": "pause_ringing", "probability": 0.9}
      ]
    },
    {
      "name": "pause_busy", "type": "event:intermediate:timer",
      "_comment": "Busy signal is near-instantaneous.",
      "cardinality_distribution": {"type": "uniform", "min": 0.5, "max": 2.0},
      "next": "emit_busy"
    },
    {
      "name": "pause_ringing", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "uniform", "min": 5, "max": 30},
      "next": "route_ringing"
    },
    {
      "name": "route_ringing", "type": "gateway:exclusive",
      "_comment": "Phone rang out — either answered or no answer.",
      "transitions": [
        {"next": "pause_answered", "probability": 0.78},
        {"next": "emit_no_answer", "probability": 0.22}
      ]
    },
    {
      "name": "pause_answered", "type": "event:intermediate:timer",
      "cardinality_distribution": {"type": "exponential", "mean": 180},
      "next": "emit_answered"
    },
    {
      "name": "emit_answered", "type": "activity",
      "_comment": "Call is in progress. Delay models talk time. CDR emitted when call ends.",
      "variables": [
        {"name": "var_disposition", "type": "string:static", "value": "ANSWERED"},
        {"name": "var_lastapp", "type": "string:static", "value": "Dial"},
        {"name": "var_lastdata", "type": "string:static", "value": "SIP/trunk,30,tTr"},
        {
          "name": "var_dstchannel", "type": "enum",
          "values": ["SIP/trunk-0001", "SIP/trunk-0002", "SIP/trunk-0003"],
          "cardinality_distribution": {"type": "uniform", "min": 0, "max": 2}
        },
        {
          "name": "var_duration", "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "exponential",
            "mean": 180
          }
        }
      ],
      "emitter": "cdr",
      "next": "call_end"
    },
    {
      "name": "emit_no_answer", "type": "activity",
      "_comment": "Rang out. CDR emitted immediately with ring duration.",
      "variables": [
        {"name": "var_disposition", "type": "string:static", "value": "NO ANSWER"},
        {"name": "var_dstchannel", "type": "string:static", "value": ""},
        {"name": "var_lastapp", "type": "string:static", "value": "Dial"},
        {"name": "var_lastdata", "type": "string:static", "value": "SIP/trunk,30,tTr"},
        {
          "name": "var_duration", "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 10,
            "max": 45
          }
        }
      ],
      "emitter": "cdr",
      "next": "call_end"
    },
    {
      "name": "emit_busy", "type": "activity",
      "_comment": "Line busy. CDR emitted immediately.",
      "variables": [
        {"name": "var_disposition", "type": "string:static", "value": "BUSY"},
        {"name": "var_dstchannel", "type": "string:static", "value": ""},
        {"name": "var_lastapp", "type": "string:static", "value": "Dial"},
        {"name": "var_lastdata", "type": "string:static", "value": "SIP/trunk,30,tTr"},
        {
          "name": "var_duration", "type": "int",
          "cardinality": 0,
          "distribution": {
            "type": "uniform",
            "min": 2,
            "max": 8
          }
        }
      ],
      "emitter": "cdr",
      "next": "call_end"
    },
    {"name": "call_end", "type": "event:end"}
  ]
}
